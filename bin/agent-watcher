#!/usr/bin/env bash
# Agent Watcher - Monitor file changes and detect agent completion
# Uses fswatch or inotify to detect real-time file changes

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
PLANS_DIR="$PROJECT_ROOT/plans"
AGENT_DIR="$PROJECT_ROOT/.agent-swarm"
WATCHER_LOG="$AGENT_DIR/logs/watcher.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
NC='\033[0m'

info() { echo -e "${BLUE}ℹ${NC} $*" | tee -a "$WATCHER_LOG"; }
success() { echo -e "${GREEN}✓${NC} $*" | tee -a "$WATCHER_LOG"; }
warn() { echo -e "${YELLOW}⚠${NC} $*" | tee -a "$WATCHER_LOG"; }
error() { echo -e "${RED}✗${NC} $*" | tee -a "$WATCHER_LOG"; }
event() { echo -e "${MAGENTA}📡${NC} $*" | tee -a "$WATCHER_LOG"; }

usage() {
  cat << EOF
Agent Watcher - File Change Detection and Completion Monitoring

Usage: agent-watcher <command>

Commands:
  start       Start watching for file changes
  stop        Stop the watcher
  status      Check watcher status
  test        Test file change detection

The watcher monitors:
  - plans/ directory for task updates
  - .agent-swarm/sessions/ for agent status changes
  - Git repository for new commits/PRs

When changes detected:
  - Parse completion signals from plan files
  - Update agent session status
  - Trigger next phase agents
  - Send notifications

Dependencies:
  - fswatch (macOS): brew install fswatch
  - inotify-tools (Linux): apt install inotify-tools

EOF
}

# Detect file watcher tool
detect_watcher() {
  if command -v fswatch &> /dev/null; then
    echo "fswatch"
  elif command -v inotifywait &> /dev/null; then
    echo "inotify"
  else
    echo "none"
  fi
}

# Install watcher if missing
install_watcher() {
  local os=$(uname -s)
  
  case "$os" in
    Darwin)
      if ! command -v fswatch &> /dev/null; then
        warn "fswatch not found. Installing via Homebrew..."
        brew install fswatch || {
          error "Failed to install fswatch. Please install manually: brew install fswatch"
          return 1
        }
      fi
      ;;
    Linux)
      if ! command -v inotifywait &> /dev/null; then
        warn "inotify-tools not found. Installing..."
        if command -v apt &> /dev/null; then
          sudo apt install -y inotify-tools
        elif command -v yum &> /dev/null; then
          sudo yum install -y inotify-tools
        else
          error "Cannot install inotify-tools automatically. Please install manually."
          return 1
        fi
      fi
      ;;
    *)
      error "Unsupported OS: $os"
      return 1
      ;;
  esac
}

# Handle file change event
handle_change() {
  local file="$1"
  local event_type="${2:-modified}"
  
  event "File changed: $file ($event_type)"
  
  # Determine file type and handle accordingly
  case "$file" in
    */plans/active/*.md)
      handle_plan_change "$file" "active"
      ;;
    */plans/in-progress/*.md)
      handle_plan_change "$file" "in-progress"
      ;;
    */plans/completed/*.md)
      handle_plan_change "$file" "completed"
      ;;
    */.agent-swarm/sessions/*.json)
      handle_session_change "$file"
      ;;
    */.agent-swarm/logs/*.log)
      handle_log_change "$file"
      ;;
  esac
}

# Handle plan file changes
handle_plan_change() {
  local file="$1"
  local stage="$2"
  local task_id=$(basename "$file" .md)
  
  info "Plan updated: $task_id ($stage)"
  
  # Check for phase completions
  if grep -q "Phase 1.*\[x\]" "$file" 2>/dev/null; then
    success "Phase 1 (Design) completed for $task_id"
    # Check if builder agent should start
    check_and_trigger_agent "$task_id" "builder"
  fi
  
  if grep -q "Phase 2.*\[x\]" "$file" 2>/dev/null; then
    success "Phase 2 (Implementation) completed for $task_id"
    # Check if reviewer agent should start
    check_and_trigger_agent "$task_id" "reviewer"
  fi
  
  if grep -q "Phase 3.*\[x\]" "$file" 2>/dev/null; then
    success "Phase 3 (Review) completed for $task_id"
    # Check if doc-gardener should start
    check_and_trigger_agent "$task_id" "doc-gardener"
  fi
  
  if grep -q "Phase 4.*\[x\]" "$file" 2>/dev/null; then
    success "Phase 4 (Integration) completed for $task_id"
    success "Task $task_id fully completed!"
  fi
  
  # Check for PR information
  local pr_num=$(grep "**PR Number:**" "$file" | sed 's/.*: //' | grep -v "TBD" || echo "")
  if [[ -n "$pr_num" ]]; then
    info "PR opened: #$pr_num for task $task_id"
  fi
}

# Handle session file changes
handle_session_change() {
  local file="$1"
  
  if [[ ! -f "$file" ]]; then
    return
  fi
  
  local role=$(jq -r '.role' "$file" 2>/dev/null || echo "unknown")
  local task_id=$(jq -r '.task_id' "$file" 2>/dev/null || echo "unknown")
  local status=$(jq -r '.status' "$file" 2>/dev/null || echo "unknown")
  
  case "$status" in
    completed)
      success "$role agent completed for task $task_id"
      ;;
    failed)
      error "$role agent failed for task $task_id"
      # TODO: Implement retry logic
      ;;
    running)
      info "$role agent running for task $task_id"
      ;;
  esac
}

# Handle log file changes
handle_log_change() {
  local file="$1"
  
  # Check for completion signals in logs
  if tail -1 "$file" | grep -q "DESIGN_COMPLETE\|BUILD_COMPLETE\|REVIEW_COMPLETE\|DOC_COMPLETE"; then
    local signal=$(tail -1 "$file" | grep -o "[A-Z_]*_COMPLETE")
    success "Completion signal detected: $signal"
  fi
}

# Check and trigger next agent
check_and_trigger_agent() {
  local task_id="$1"
  local role="$2"
  
  local session_file="$AGENT_DIR/sessions/${task_id}-${role}.json"
  
  if [[ ! -f "$session_file" ]]; then
    warn "Session file not found: $session_file"
    return 1
  fi
  
  local status=$(jq -r '.status' "$session_file")
  
  if [[ "$status" == "active" ]]; then
    info "Triggering $role agent for task $task_id..."
    # Update status to trigger daemon execution
    jq '.status = "active" | .triggered_at = "'$(date -Iseconds)'"' "$session_file" > "$session_file.tmp"
    mv "$session_file.tmp" "$session_file"
  fi
}

# Watch using fswatch (macOS)
watch_fswatch() {
  info "Starting fswatch on $PROJECT_ROOT..."
  
  fswatch -r \
    --event Created \
    --event Updated \
    --event Removed \
    --event Renamed \
    "$PLANS_DIR" \
    "$AGENT_DIR/sessions" \
    "$AGENT_DIR/logs" \
    2>/dev/null | while read -r file; do
    handle_change "$file"
  done
}

# Watch using inotify (Linux)
watch_inotify() {
  info "Starting inotifywait on $PROJECT_ROOT..."
  
  inotifywait -m -r \
    -e modify,create,delete,move \
    "$PLANS_DIR" \
    "$AGENT_DIR/sessions" \
    "$AGENT_DIR/logs" \
    2>/dev/null | while read -r path event file; do
    handle_change "$path$file" "$event"
  done
}

# Fallback: polling-based watch
watch_poll() {
  warn "No file watcher available. Using polling (slower)..."
  
  local last_check=$(date +%s)
  
  while true; do
    local current=$(date +%s)
    
    # Check for modified files in last 10 seconds
    find "$PLANS_DIR" "$AGENT_DIR/sessions" "$AGENT_DIR/logs" \
      -type f \
      -newermt "@$last_check" \
      2>/dev/null | while read -r file; do
      handle_change "$file" "modified"
    done
    
    last_check=$current
    sleep 10
  done
}

# Start watcher
cmd_start() {
  mkdir -p "$AGENT_DIR/logs"
  touch "$WATCHER_LOG"
  
  local watcher=$(detect_watcher)
  
  if [[ "$watcher" == "none" ]]; then
    warn "No file watcher found. Attempting to install..."
    install_watcher || {
      error "Cannot install file watcher. Falling back to polling."
      watcher="poll"
    }
    watcher=$(detect_watcher)
  fi
  
  info "Using watcher: $watcher"
  
  case "$watcher" in
    fswatch)
      watch_fswatch
      ;;
    inotify)
      watch_inotify
      ;;
    *)
      watch_poll
      ;;
  esac
}

# Test watcher
cmd_test() {
  info "Testing file change detection..."
  
  local test_file="$AGENT_DIR/test-$(date +%s).txt"
  
  echo "Test file" > "$test_file"
  sleep 1
  echo "Modified" >> "$test_file"
  sleep 1
  rm "$test_file"
  
  success "Test complete. Check logs: $WATCHER_LOG"
}

# Main
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  
  local command="$1"
  shift
  
  case "$command" in
    start)
      cmd_start
      ;;
    test)
      cmd_test
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      error "Unknown command: $command"
      usage
      exit 1
      ;;
  esac
}

main "$@"
