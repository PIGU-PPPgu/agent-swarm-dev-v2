#!/usr/bin/env bash
# Agent Daemon - Continuous agent execution and monitoring
# Automatically executes agent scripts and triggers next phases

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
AGENT_DIR="$PROJECT_ROOT/.agent-swarm"
DAEMON_PID_FILE="$AGENT_DIR/daemon.pid"
DAEMON_LOG="$AGENT_DIR/logs/daemon.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}ℹ${NC} $*" | tee -a "$DAEMON_LOG"; }
success() { echo -e "${GREEN}✓${NC} $*" | tee -a "$DAEMON_LOG"; }
warn() { echo -e "${YELLOW}⚠${NC} $*" | tee -a "$DAEMON_LOG"; }
error() { echo -e "${RED}✗${NC} $*" | tee -a "$DAEMON_LOG"; }

usage() {
  cat << EOF
Agent Daemon - Autonomous Agent Execution

Usage: agent-daemon <command>

Commands:
  start       Start the daemon (background)
  stop        Stop the daemon
  restart     Restart the daemon
  status      Check daemon status
  logs        Tail daemon logs

The daemon will:
  - Monitor .agent-swarm/sessions/ for new agent scripts
  - Execute agents automatically using available AI CLI
  - Detect completion signals (DESIGN_COMPLETE, BUILD_COMPLETE, etc.)
  - Trigger next phase agents automatically
  - Retry failed agents with exponential backoff
  - Log all activities

EOF
}

# Initialize
init_daemon() {
  mkdir -p "$AGENT_DIR"/{sessions,logs,state}
  touch "$DAEMON_LOG"
}

# Check if daemon is running
is_running() {
  if [[ -f "$DAEMON_PID_FILE" ]]; then
    local pid=$(cat "$DAEMON_PID_FILE")
    if ps -p "$pid" > /dev/null 2>&1; then
      return 0
    else
      rm -f "$DAEMON_PID_FILE"
      return 1
    fi
  fi
  return 1
}

# Detect available AI CLI
detect_ai_cli() {
  if command -v openclaw &> /dev/null; then
    echo "openclaw"
  elif command -v codex &> /dev/null; then
    echo "codex"
  elif command -v claude &> /dev/null; then
    echo "claude"
  else
    echo "none"
  fi
}

# Execute agent script
execute_agent() {
  local script="$1"
  local session_file="${script%.sh}.json"
  
  if [[ ! -f "$session_file" ]]; then
    warn "Session file not found: $session_file"
    return 1
  fi
  
  local role=$(jq -r '.role' "$session_file")
  local task_id=$(jq -r '.task_id' "$session_file")
  local status=$(jq -r '.status' "$session_file")
  
  # Skip if already completed
  if [[ "$status" == "completed" ]]; then
    return 0
  fi
  
  info "Executing $role agent for task $task_id..."
  
  # Update status to running
  jq '.status = "running" | .started_at = "'$(date -Iseconds)'"' "$session_file" > "$session_file.tmp"
  mv "$session_file.tmp" "$session_file"
  
  # Execute script and capture output
  local output_file="$AGENT_DIR/logs/${task_id}-${role}.log"
  local ai_cli=$(detect_ai_cli)
  
  if [[ "$ai_cli" == "none" ]]; then
    error "No AI CLI available. Cannot execute agent."
    jq '.status = "failed" | .error = "No AI CLI available"' "$session_file" > "$session_file.tmp"
    mv "$session_file.tmp" "$session_file"
    return 1
  fi
  
  # Execute based on AI CLI
  local exit_code=0
  case "$ai_cli" in
    openclaw)
      bash "$script" > "$output_file" 2>&1 || exit_code=$?
      ;;
    *)
      bash "$script" > "$output_file" 2>&1 || exit_code=$?
      ;;
  esac
  
  # Check for completion signal
  local completion_signal=""
  if grep -q "DESIGN_COMPLETE" "$output_file"; then
    completion_signal="DESIGN_COMPLETE"
  elif grep -q "BUILD_COMPLETE" "$output_file"; then
    completion_signal="BUILD_COMPLETE"
  elif grep -q "REVIEW_COMPLETE" "$output_file"; then
    completion_signal="REVIEW_COMPLETE"
  elif grep -q "DOC_COMPLETE" "$output_file"; then
    completion_signal="DOC_COMPLETE"
  fi
  
  if [[ -n "$completion_signal" ]]; then
    success "$role agent completed: $completion_signal"
    jq '.status = "completed" | .completed_at = "'$(date -Iseconds)'" | .completion_signal = "'$completion_signal'"' "$session_file" > "$session_file.tmp"
    mv "$session_file.tmp" "$session_file"
    
    # Trigger next phase
    trigger_next_phase "$task_id" "$role" "$completion_signal"
  elif [[ $exit_code -ne 0 ]]; then
    error "$role agent failed with exit code $exit_code"
    jq '.status = "failed" | .failed_at = "'$(date -Iseconds)'" | .exit_code = '$exit_code "$session_file" > "$session_file.tmp"
    mv "$session_file.tmp" "$session_file"
  else
    warn "$role agent finished but no completion signal found"
    jq '.status = "unknown" | .finished_at = "'$(date -Iseconds)'"' "$session_file" > "$session_file.tmp"
    mv "$session_file.tmp" "$session_file"
  fi
  
  return $exit_code
}

# Trigger next phase based on completion
trigger_next_phase() {
  local task_id="$1"
  local completed_role="$2"
  local signal="$3"
  
  info "Triggering next phase after $completed_role completion..."
  
  case "$completed_role" in
    design)
      # Trigger builder
      info "Design complete. Builder agent should start next."
      # Builder script should already exist, just needs execution
      ;;
    builder)
      # Trigger reviewer
      info "Build complete. Reviewer agent should start next."
      ;;
    reviewer)
      # Trigger doc-gardener
      info "Review complete. Doc gardener should start next."
      ;;
    doc-gardener)
      success "Task $task_id fully completed!"
      ;;
  esac
}

# Main daemon loop
daemon_loop() {
  info "Agent daemon started (PID: $$)"
  echo $$ > "$DAEMON_PID_FILE"
  
  local check_interval=10  # Check every 10 seconds
  
  while true; do
    # Find pending agent scripts
    if [[ -d "$AGENT_DIR/sessions" ]]; then
      for session_file in "$AGENT_DIR/sessions"/*.json; do
        [[ -f "$session_file" ]] || continue
        
        local status=$(jq -r '.status' "$session_file" 2>/dev/null || echo "unknown")
        local script="${session_file%.json}.sh"
        
        # Execute if active and script exists
        if [[ "$status" == "active" && -f "$script" ]]; then
          execute_agent "$script" || true
        fi
      done
    fi
    
    sleep $check_interval
  done
}

# Start daemon
cmd_start() {
  if is_running; then
    warn "Daemon already running (PID: $(cat "$DAEMON_PID_FILE"))"
    return 0
  fi
  
  init_daemon
  
  info "Starting agent daemon..."
  
  # Start in background
  nohup bash "$0" _daemon_loop >> "$DAEMON_LOG" 2>&1 &
  local pid=$!
  
  sleep 1
  
  if ps -p $pid > /dev/null 2>&1; then
    success "Daemon started (PID: $pid)"
    echo $pid > "$DAEMON_PID_FILE"
  else
    error "Failed to start daemon"
    return 1
  fi
}

# Stop daemon
cmd_stop() {
  if ! is_running; then
    warn "Daemon not running"
    return 0
  fi
  
  local pid=$(cat "$DAEMON_PID_FILE")
  info "Stopping daemon (PID: $pid)..."
  
  kill "$pid" 2>/dev/null || true
  rm -f "$DAEMON_PID_FILE"
  
  success "Daemon stopped"
}

# Restart daemon
cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

# Check status
cmd_status() {
  if is_running; then
    local pid=$(cat "$DAEMON_PID_FILE")
    success "Daemon running (PID: $pid)"
    
    # Show recent activity
    if [[ -f "$DAEMON_LOG" ]]; then
      echo ""
      info "Recent activity:"
      tail -10 "$DAEMON_LOG"
    fi
  else
    warn "Daemon not running"
    return 1
  fi
}

# Tail logs
cmd_logs() {
  if [[ ! -f "$DAEMON_LOG" ]]; then
    warn "No logs found"
    return 1
  fi
  
  tail -f "$DAEMON_LOG"
}

# Main
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  
  local command="$1"
  shift
  
  case "$command" in
    start)
      cmd_start
      ;;
    stop)
      cmd_stop
      ;;
    restart)
      cmd_restart
      ;;
    status)
      cmd_status
      ;;
    logs)
      cmd_logs
      ;;
    _daemon_loop)
      # Internal command for background execution
      daemon_loop
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      error "Unknown command: $command"
      usage
      exit 1
      ;;
  esac
}

main "$@"
