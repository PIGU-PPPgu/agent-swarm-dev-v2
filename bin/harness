#!/usr/bin/env bash
# Harness Quality Tools for Agent Swarm Development
# Integrated quality commands for maintaining code and documentation standards

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
info() { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
error() { echo -e "${RED}✗${NC} $*"; }

usage() {
  cat << EOF
Harness Quality Tools - Agent Swarm Development

Usage: harness <command> [options]

Commands:
  init              Initialize project structure
  audit             Audit code quality and agent readability
  enforce           Enforce architecture constraints
  garden            Cleanup stale documentation and code
  golden-rules      Apply best practices refactoring

Options:
  -h, --help        Show this help message

Examples:
  harness init                    # Initialize project
  harness audit                   # Full audit
  harness audit --score           # Show score only
  harness enforce --check         # Check constraints (no changes)
  harness garden --docs-only      # Cleanup docs only
  harness golden-rules --check    # Check golden rules violations

For detailed documentation, see SKILL.md
EOF
}

cmd_init() {
  info "Initializing Harness project structure..."
  
  # Create directory structure
  mkdir -p "$PROJECT_ROOT/docs"/{architecture,design-docs,exec-plans,product-specs,references,quality}
  mkdir -p "$PROJECT_ROOT/plans"/{active,completed,debt}
  mkdir -p "$PROJECT_ROOT/.harness"
  
  # Create initial files
  if [[ ! -f "$PROJECT_ROOT/docs/architecture/index.md" ]]; then
    cat > "$PROJECT_ROOT/docs/architecture/index.md" << 'EOARCH'
# Architecture Overview

## System Structure

[Add high-level architecture diagram]

## Layers

- **UI Layer** - User interface components
- **Runtime Layer** - Application runtime and initialization
- **Service Layer** - Business logic
- **Repository Layer** - Data access
- **Config Layer** - Configuration
- **Types Layer** - Type definitions

## Dependency Rules

Code can only depend "forward" in the layer hierarchy.
No circular dependencies allowed.
EOARCH
    success "Created docs/architecture/index.md"
  fi
  
  if [[ ! -f "$PROJECT_ROOT/docs/principles.md" ]]; then
    cat > "$PROJECT_ROOT/docs/principles.md" << 'EOPRINCIPLES'
# Golden Rules

## 1. Shared Utilities
Use shared utility packages instead of duplicating logic.

## 2. Boundary Validation
Validate all external data at system boundaries using schemas.

## 3. Typed SDKs
Use generated API clients instead of manual requests.

## 4. Centralized Invariants
Encode rules in tools, not scattered in code.
EOPRINCIPLES
    success "Created docs/principles.md"
  fi
  
  if [[ ! -f "$PROJECT_ROOT/.harness/config.json" ]]; then
    cat > "$PROJECT_ROOT/.harness/config.json" << 'EOCONFIG'
{
  "architecture": {
    "layers": ["types", "config", "repository", "service", "runtime", "ui"],
    "allowedDependencies": {
      "ui": ["runtime", "service", "types"],
      "runtime": ["service", "config", "types"],
      "service": ["repository", "config", "types"],
      "repository": ["config", "types"],
      "config": ["types"],
      "types": []
    }
  },
  "quality": {
    "minCoverage": 80,
    "maxFileSize": 500,
    "maxFunctionLength": 50
  }
}
EOCONFIG
    success "Created .harness/config.json"
  fi
  
  success "Harness project structure initialized!"
  info "Next steps:"
  info "  1. Edit docs/architecture/index.md to describe your system"
  info "  2. Edit docs/principles.md to define your golden rules"
  info "  3. Run 'harness audit' to check current quality"
}

cmd_audit() {
  info "Auditing project quality..."
  
  local score=0
  local max_score=100
  local issues=()
  
  # Check documentation coverage
  if [[ -d "$PROJECT_ROOT/docs/architecture" ]]; then
    score=$((score + 20))
    success "Architecture documentation exists"
  else
    issues+=("Missing architecture documentation (-20)")
  fi
  
  if [[ -f "$PROJECT_ROOT/docs/principles.md" ]]; then
    score=$((score + 15))
    success "Principles documented"
  else
    issues+=("Missing principles documentation (-15)")
  fi
  
  # Check for AGENTS.md
  if [[ -f "$PROJECT_ROOT/AGENTS.md" ]]; then
    score=$((score + 10))
    success "AGENTS.md exists"
  else
    issues+=("Missing AGENTS.md (-10)")
  fi
  
  # Check for execution plans
  if [[ -d "$PROJECT_ROOT/plans/active" ]]; then
    local plan_count=$(find "$PROJECT_ROOT/plans/active" -name "*.md" 2>/dev/null | wc -l)
    if [[ $plan_count -gt 0 ]]; then
      score=$((score + 15))
      success "Execution plans exist ($plan_count active)"
    else
      issues+=("No active execution plans (-15)")
    fi
  else
    issues+=("Missing plans directory (-15)")
  fi
  
  # Check for tests
  if [[ -d "$PROJECT_ROOT/tests" ]] || [[ -d "$PROJECT_ROOT/test" ]] || [[ -d "$PROJECT_ROOT/__tests__" ]]; then
    score=$((score + 20))
    success "Test directory exists"
  else
    issues+=("No test directory found (-20)")
  fi
  
  # Check for linter config
  if [[ -f "$PROJECT_ROOT/.eslintrc.js" ]] || [[ -f "$PROJECT_ROOT/.eslintrc.json" ]] || [[ -f "$PROJECT_ROOT/eslint.config.js" ]]; then
    score=$((score + 10))
    success "Linter configured"
  else
    issues+=("No linter configuration (-10)")
  fi
  
  # Check for CI
  if [[ -d "$PROJECT_ROOT/.github/workflows" ]]; then
    score=$((score + 10))
    success "CI/CD configured"
  else
    issues+=("No CI/CD configuration (-10)")
  fi
  
  echo ""
  echo -e "${BLUE}📊 Agent Readability Score: ${score}/${max_score}${NC}"
  echo ""
  
  if [[ ${#issues[@]} -gt 0 ]]; then
    warn "Issues found:"
    for issue in "${issues[@]}"; do
      echo "  - $issue"
    done
    echo ""
    info "Run 'harness init' to create missing structure"
  else
    success "Project is well-structured for agent development!"
  fi
  
  # Show score interpretation
  if [[ $score -ge 80 ]]; then
    success "Excellent! Project is highly readable for agents."
  elif [[ $score -ge 60 ]]; then
    info "Good. Some improvements recommended."
  elif [[ $score -ge 40 ]]; then
    warn "Fair. Several improvements needed."
  else
    error "Poor. Significant improvements required."
  fi
}

cmd_enforce() {
  local check_only=false
  local violations=0
  
  if [[ "${1:-}" == "--check" ]]; then
    check_only=true
  fi
  
  info "Checking architecture constraints..."
  
  # Check if config exists
  if [[ ! -f "$PROJECT_ROOT/.harness/config.json" ]]; then
    error "No .harness/config.json found. Run 'harness init' first."
    return 1
  fi
  
  # Check for circular dependencies (if madge is available)
  if command -v madge &> /dev/null; then
    info "Checking for circular dependencies..."
    if madge --circular "$PROJECT_ROOT/src" 2>/dev/null | grep -q "Circular"; then
      error "Circular dependencies found"
      violations=$((violations + 1))
    else
      success "No circular dependencies"
    fi
  fi
  
  # Check file sizes
  info "Checking file sizes..."
  local large_files=$(find "$PROJECT_ROOT/src" -name "*.ts" -o -name "*.js" 2>/dev/null | while read -r file; do
    local lines=$(wc -l < "$file")
    if [[ $lines -gt 500 ]]; then
      echo "$file ($lines lines)"
    fi
  done)
  
  if [[ -n "$large_files" ]]; then
    warn "Large files found (>500 lines):"
    echo "$large_files" | while read -r line; do
      echo "  - $line"
    done
    violations=$((violations + 1))
  else
    success "All files within size limits"
  fi
  
  # Check for unvalidated API calls
  info "Checking for unvalidated API calls..."
  local unvalidated=$(grep -r "\.json()" "$PROJECT_ROOT/src" 2>/dev/null | grep -v "parse\|validate\|schema" | wc -l)
  if [[ $unvalidated -gt 0 ]]; then
    warn "Found $unvalidated potential unvalidated API calls"
    info "Consider using Zod schemas for validation"
    violations=$((violations + 1))
  else
    success "API calls appear to be validated"
  fi
  
  echo ""
  if [[ $violations -eq 0 ]]; then
    success "Architecture constraints check passed ✓"
  else
    error "Found $violations constraint violations"
    if [[ "$check_only" == false ]]; then
      info "Run with --check to see violations without making changes"
    fi
    return 1
  fi
  
  if [[ "$check_only" == false ]]; then
    info "Generating enforcement rules..."
    
    # Generate ESLint rule for file size
    if [[ ! -f "$PROJECT_ROOT/.eslintrc.json" ]]; then
      cat > "$PROJECT_ROOT/.eslintrc.json" << 'EOESLINT'
{
  "rules": {
    "max-lines": ["warn", 500],
    "max-lines-per-function": ["warn", 50],
    "complexity": ["warn", 10]
  }
}
EOESLINT
      success "Generated .eslintrc.json"
    fi
    
    success "Enforcement rules generated"
  fi
}

cmd_garden() {
  local mode="${1:---all}"
  local issues_found=0
  
  info "Running garden cleanup ($mode)..."
  
  if [[ "$mode" == "--docs-only" ]] || [[ "$mode" == "--all" ]]; then
    info "Scanning documentation..."
    
    # Check for broken links in markdown files
    if [[ -d "$PROJECT_ROOT/docs" ]]; then
      local broken_links=$(find "$PROJECT_ROOT/docs" -name "*.md" -exec grep -H '\[.*\](.*)' {} \; 2>/dev/null | \
        grep -v 'http' | \
        while read -r line; do
          local file=$(echo "$line" | cut -d: -f1)
          local link=$(echo "$line" | sed -n 's/.*\[\(.*\)\](\(.*\)).*/\2/p')
          if [[ -n "$link" ]] && [[ ! -f "$PROJECT_ROOT/$link" ]]; then
            echo "$file: broken link to $link"
          fi
        done)
      
      if [[ -n "$broken_links" ]]; then
        warn "Broken links found:"
        echo "$broken_links" | while read -r line; do
          echo "  - $line"
        done
        issues_found=$((issues_found + 1))
      else
        success "No broken links in documentation"
      fi
      
      # Check for outdated docs (not modified in 90 days)
      local old_docs=$(find "$PROJECT_ROOT/docs" -name "*.md" -mtime +90 2>/dev/null)
      if [[ -n "$old_docs" ]]; then
        warn "Documentation not updated in 90+ days:"
        echo "$old_docs" | while read -r file; do
          echo "  - $(basename "$file")"
        done
        issues_found=$((issues_found + 1))
      else
        success "Documentation is up to date"
      fi
    fi
  fi
  
  if [[ "$mode" == "--code-only" ]] || [[ "$mode" == "--all" ]]; then
    info "Scanning code..."
    
    # Check for duplicate code patterns
    if [[ -d "$PROJECT_ROOT/src" ]]; then
      # Look for common duplicate patterns
      local duplicate_functions=$(grep -r "^function \(debounce\|throttle\|formatDate\)" "$PROJECT_ROOT/src" 2>/dev/null | wc -l)
      if [[ $duplicate_functions -gt 1 ]]; then
        warn "Found $duplicate_functions duplicate utility functions"
        info "Consider extracting to shared utils package"
        issues_found=$((issues_found + 1))
      else
        success "No obvious duplicate functions"
      fi
      
      # Check for unused exports
      if command -v ts-prune &> /dev/null; then
        local unused=$(ts-prune "$PROJECT_ROOT" 2>/dev/null | grep -c "used in module")
        if [[ $unused -gt 0 ]]; then
          warn "Found $unused potentially unused exports"
          issues_found=$((issues_found + 1))
        else
          success "No unused exports detected"
        fi
      fi
    fi
  fi
  
  echo ""
  if [[ $issues_found -eq 0 ]]; then
    success "Garden cleanup complete - no issues found ✓"
  else
    warn "Found $issues_found issues that need attention"
    info "Consider creating PRs to fix these issues"
  fi
}

cmd_golden_rules() {
  local check_only=false
  local violations=0
  
  if [[ "${1:-}" == "--check" ]]; then
    check_only=true
  fi
  
  info "Checking golden rules..."
  
  if [[ ! -d "$PROJECT_ROOT/src" ]]; then
    warn "No src directory found, skipping code checks"
    return 0
  fi
  
  # Rule 1: Shared utilities
  info "Checking for inline utility functions..."
  local inline_utils=$(grep -r "^function \(debounce\|throttle\|formatDate\|parseJSON\)" "$PROJECT_ROOT/src" 2>/dev/null)
  if [[ -n "$inline_utils" ]]; then
    warn "Found inline utility functions:"
    echo "$inline_utils" | while read -r line; do
      echo "  - $line"
    done
    info "→ Extract to shared utils package"
    violations=$((violations + 1))
  else
    success "No inline utility functions found"
  fi
  
  # Rule 2: Boundary validation
  info "Checking for unvalidated API responses..."
  local unvalidated=$(grep -r "\.json()" "$PROJECT_ROOT/src" 2>/dev/null | grep -v "parse\|validate\|schema")
  if [[ -n "$unvalidated" ]]; then
    warn "Found unvalidated API responses:"
    echo "$unvalidated" | head -5 | while read -r line; do
      echo "  - $line"
    done
    info "→ Use Zod schemas for validation"
    violations=$((violations + 1))
  else
    success "API responses appear to be validated"
  fi
  
  # Rule 3: Typed SDKs
  info "Checking for manual API requests..."
  local manual_requests=$(grep -r "axios\.post\|fetch(" "$PROJECT_ROOT/src" 2>/dev/null | wc -l)
  if [[ $manual_requests -gt 5 ]]; then
    warn "Found $manual_requests manual API requests"
    info "→ Consider using generated API client"
    violations=$((violations + 1))
  else
    success "API requests look reasonable"
  fi
  
  # Rule 4: Magic numbers
  info "Checking for magic numbers..."
  local magic_numbers=$(grep -r "setTimeout\|setInterval" "$PROJECT_ROOT/src" 2>/dev/null | grep -E "[0-9]{3,}" | wc -l)
  if [[ $magic_numbers -gt 0 ]]; then
    warn "Found $magic_numbers potential magic numbers in timeouts"
    info "→ Extract to named constants"
    violations=$((violations + 1))
  else
    success "No obvious magic numbers"
  fi
  
  echo ""
  if [[ $violations -eq 0 ]]; then
    success "Golden rules check passed ✓"
  else
    warn "Found $violations golden rule violations"
    
    if [[ "$check_only" == false ]]; then
      info ""
      info "To fix these issues:"
      info "  1. Extract inline utilities to src/utils/"
      info "  2. Add Zod schemas for API validation"
      info "  3. Consider generating API client from OpenAPI spec"
      info "  4. Extract magic numbers to constants"
      info ""
      info "Run with --check to see violations without suggestions"
    fi
    return 1
  fi
}

# Main command dispatcher
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  
  local command="$1"
  shift
  
  case "$command" in
    init)
      cmd_init "$@"
      ;;
    audit)
      cmd_audit "$@"
      ;;
    enforce)
      cmd_enforce "$@"
      ;;
    garden)
      cmd_garden "$@"
      ;;
    golden-rules)
      cmd_golden_rules "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
