#!/usr/bin/env bash
# Agent Orchestrator - Main coordinator for agent swarm development
# Receives high-level tasks and coordinates specialized agents

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
PLANS_DIR="$PROJECT_ROOT/plans"
AGENT_DIR="$PROJECT_ROOT/.agent-swarm"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helper functions
info() { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
error() { echo -e "${RED}✗${NC} $*"; }
agent() { echo -e "${MAGENTA}🤖${NC} $*"; }
step() { echo -e "${CYAN}→${NC} $*"; }

usage() {
  cat << EOF
Agent Orchestrator - Autonomous Development Workflow

Usage: agent-orchestrator <command> [options]

Commands:
  run <task>           Execute a high-level task autonomously
  status               Show current agent activities
  watch                Watch and coordinate agents in real-time
  stop [task-id]       Stop agents (all or specific task)

Examples:
  agent-orchestrator run "Implement user authentication"
  agent-orchestrator run "Fix bug #123"
  agent-orchestrator watch
  agent-orchestrator status
  agent-orchestrator stop task-xxx

The orchestrator will:
  1. Analyze the task and create execution plan
  2. Spawn Design Agent to create design document
  3. Spawn Builder Agent to implement code
  4. Spawn Reviewer Agents for code review
  5. Handle feedback loops automatically
  6. Spawn Doc Gardener to update documentation
  7. Mark task as complete

All agents communicate via execution plans in plans/ directory.

EOF
}

# Initialize project structure
init_project() {
  if [[ ! -d "$PLANS_DIR" ]]; then
    info "Initializing project structure..."
    mkdir -p "$PLANS_DIR"/{active,in-progress,completed,failed}
    mkdir -p "$PROJECT_ROOT/docs"/{design-docs,architecture}
    mkdir -p "$AGENT_DIR"/{sessions,logs}
    success "Project structure initialized"
  fi
  
  # Ensure directories exist
  mkdir -p "$AGENT_DIR"/{sessions,logs}
}

# Generate unique task ID
generate_task_id() {
  echo "task-$(date +%Y%m%d-%H%M%S)-$(openssl rand -hex 3)"
}

# Create execution plan
create_execution_plan() {
  local task="$1"
  local task_id="$2"
  local plan_file="$PLANS_DIR/active/${task_id}.md"
  
  step "Creating execution plan..."
  
  cat > "$plan_file" << EOF
# Task: $task

**ID:** $task_id
**Status:** active
**Created:** $(date -Iseconds)
**Owner:** orchestrator

## Goal
$task

## Execution Steps

### Phase 1: Design
- [ ] Analyze requirements
- [ ] Create design document (docs/design-docs/${task_id}.md)
- [ ] Define architecture impact

### Phase 2: Implementation
- [ ] Implement core functionality
- [ ] Write unit tests
- [ ] Run quality checks (/harness enforce --check)
- [ ] Open PR

### Phase 3: Review
- [ ] Self-review
- [ ] Request agent reviews (security, performance)
- [ ] Address feedback
- [ ] Re-run quality checks

### Phase 4: Integration
- [ ] Merge PR
- [ ] Update documentation
- [ ] Run /harness garden
- [ ] Mark as complete

## Agent Assignments
- **Design Agent:** Pending
- **Builder Agent:** Pending
- **Reviewer Agent:** Pending
- **Doc Agent:** Pending

## Progress Log
- $(date -Iseconds): Task created by orchestrator

## Decisions
(To be filled by agents)

## PR Information
- **PR Number:** TBD
- **PR URL:** TBD

## Blockers
None

---
*This plan is managed by the agent orchestrator*
*Agents: Update this file as you make progress*
EOF
  
  success "Execution plan created: $plan_file"
  echo "$plan_file"
}

# Spawn agent using OpenClaw sessions_spawn
spawn_agent_real() {
  local role="$1"
  local task_id="$2"
  local context="$3"
  local plan_file="$4"
  
  agent "Spawning $role agent for task $task_id..."
  
  # Build agent-specific prompt
  local agent_prompt=""
  local agent_label="agent-swarm-${role}-${task_id}"
  
  case "$role" in
    design)
      agent_prompt="You are a Design Agent in an autonomous development team.

Your task: Read plans/active/${task_id}.md and create a comprehensive design document.

Steps:
1. Read the task plan: cat plans/active/${task_id}.md
2. Run quality audit: $SCRIPT_DIR/harness audit
3. Create design document in docs/design-docs/${task_id}.md with:
   - Requirements analysis
   - Architecture impact
   - Data models
   - API contracts
   - Security considerations
4. Update the task plan:
   - Mark Phase 1 steps as complete
   - Add your decisions to Decisions section
   - Update Progress Log
   - Update Agent Assignments (Design Agent: Complete)
5. Move plan to in-progress: mv plans/active/${task_id}.md plans/in-progress/${task_id}.md

Context: $context

When done, your final message should be: DESIGN_COMPLETE"
      ;;
      
    builder)
      agent_prompt="You are a Builder Agent in an autonomous development team.

Your task: Implement the solution described in plans/in-progress/${task_id}.md

Steps:
1. Read the task plan: cat plans/in-progress/${task_id}.md
2. Read the design document: cat docs/design-docs/${task_id}.md
3. Run architecture check: $SCRIPT_DIR/harness enforce --check
4. Implement the solution following the design
5. Write comprehensive tests (unit + integration)
6. Run quality checks: $SCRIPT_DIR/harness enforce --check
7. Open a PR using gh CLI
8. Update the task plan:
   - Mark Phase 2 steps as complete
   - Add PR number and URL to PR Information section
   - Update Progress Log
   - Update Agent Assignments (Builder Agent: Complete)

Context: $context

When done, your final message should be: BUILD_COMPLETE PR#<number>"
      ;;
      
    reviewer)
      agent_prompt="You are a Reviewer Agent in an autonomous development team.

Your task: Review the PR mentioned in plans/in-progress/${task_id}.md

Steps:
1. Read the task plan: cat plans/in-progress/${task_id}.md
2. Get PR number from the plan
3. Run quality audit on PR: $SCRIPT_DIR/harness audit
4. Run architecture check: $SCRIPT_DIR/harness enforce --check
5. Review the code using gh CLI:
   - Check architecture compliance
   - Verify test coverage
   - Check for security issues
   - Verify golden rules compliance
6. Leave detailed review comments
7. Update the task plan:
   - Mark Phase 3 steps as complete
   - Add review findings to Decisions section
   - Update Progress Log
   - Update Agent Assignments (Reviewer Agent: Complete)

Focus: $context

When done, your final message should be: REVIEW_COMPLETE [APPROVED|CHANGES_REQUESTED]"
      ;;
      
    doc-gardener)
      agent_prompt="You are a Doc Gardener Agent in an autonomous development team.

Your task: Update documentation for the changes in plans/in-progress/${task_id}.md

Steps:
1. Read the task plan: cat plans/in-progress/${task_id}.md
2. Get PR number from the plan
3. Run doc cleanup: $SCRIPT_DIR/harness garden --docs-only
4. Update relevant documentation:
   - Update architecture docs if needed
   - Update API docs
   - Update README if needed
5. Create a documentation PR
6. Update the task plan:
   - Mark Phase 4 steps as complete
   - Update Progress Log
   - Update Agent Assignments (Doc Agent: Complete)
7. Move plan to completed: mv plans/in-progress/${task_id}.md plans/completed/${task_id}.md

Context: $context

When done, your final message should be: DOC_COMPLETE"
      ;;
      
    *)
      error "Unknown agent role: $role"
      return 1
      ;;
  esac
  
  # Log agent spawn
  local log_file="$AGENT_DIR/logs/orchestrator.log"
  echo "$(date -Iseconds) | SPAWN | $role | $task_id | $context" >> "$log_file"
  
  # Create session tracking file
  local session_file="$AGENT_DIR/sessions/${task_id}-${role}.json"
  
  # Spawn using OpenClaw (this is a placeholder - actual implementation would use OpenClaw's API)
  # For now, we'll create a script that can be run manually or by a daemon
  local agent_script="$AGENT_DIR/sessions/${task_id}-${role}.sh"
  
  cat > "$agent_script" << EOSCRIPT
#!/usr/bin/env bash
# Agent: $role
# Task: $task_id
# Generated: $(date -Iseconds)

cd "$PROJECT_ROOT"

echo "🤖 $role Agent starting..."
echo "Task ID: $task_id"
echo "Plan: $plan_file"
echo ""

# Agent prompt
cat << 'EOPROMPT'
$agent_prompt
EOPROMPT

echo ""
echo "To execute this agent, run:"
echo "  openclaw chat --cwd '$PROJECT_ROOT' --task '\$(cat $agent_script | grep -A 999 'EOPROMPT' | grep -B 999 'EOPROMPT' | grep -v EOPROMPT)'"
echo ""
echo "Or manually execute the steps above."
EOSCRIPT
  
  chmod +x "$agent_script"
  
  # Save session info
  cat > "$session_file" << EOSESSION
{
  "role": "$role",
  "task_id": "$task_id",
  "context": "$context",
  "plan_file": "$plan_file",
  "script": "$agent_script",
  "spawned_at": "$(date -Iseconds)",
  "status": "active"
}
EOSESSION
  
  success "$role agent spawned"
  info "Agent script: $agent_script"
  info "To run manually: bash $agent_script"
  
  # Return session file path
  echo "$session_file"
}

# Check if agent completed
check_agent_completion() {
  local task_id="$1"
  local role="$2"
  local plan_file="$3"
  
  # Check if plan was updated by agent
  if [[ -f "$plan_file" ]]; then
    local agent_assignment=$(grep -A 1 "**${role^} Agent:**" "$plan_file" | tail -1)
    if echo "$agent_assignment" | grep -q "Complete"; then
      return 0
    fi
  fi
  
  # Check if plan moved to next stage
  case "$role" in
    design)
      [[ -f "$PLANS_DIR/in-progress/${task_id}.md" ]] && return 0
      ;;
    builder|reviewer)
      # Check if next phase is marked complete
      grep -q "Phase [34].*\[x\]" "$plan_file" 2>/dev/null && return 0
      ;;
    doc-gardener)
      [[ -f "$PLANS_DIR/completed/${task_id}.md" ]] && return 0
      ;;
  esac
  
  return 1
}

# Main orchestration workflow
cmd_run() {
  local task="$*"
  
  if [[ -z "$task" ]]; then
    error "Task description required"
    usage
    return 1
  fi
  
  init_project
  
  echo ""
  info "🚀 Starting autonomous development workflow"
  echo ""
  info "Task: $task"
  echo ""
  
  # Generate task ID
  local task_id=$(generate_task_id)
  info "Task ID: $task_id"
  echo ""
  
  # Create execution plan
  local plan_file=$(create_execution_plan "$task" "$task_id")
  echo ""
  
  # Phase 1: Design
  step "Phase 1: Design"
  local design_session=$(spawn_agent_real "design" "$task_id" "Analyze task and create design document" "$plan_file")
  echo ""
  
  info "Design agent spawned. Waiting for completion..."
  info "(Check progress: agent-orchestrator status)"
  echo ""
  
  # Phase 2: Implementation
  step "Phase 2: Implementation"
  info "Builder agent will be spawned after design is complete"
  local builder_session=$(spawn_agent_real "builder" "$task_id" "Implement solution from design" "$plan_file")
  echo ""
  
  # Phase 3: Review
  step "Phase 3: Review"
  info "Reviewer agents will be spawned after PR is opened"
  local reviewer_session=$(spawn_agent_real "reviewer" "$task_id" "security" "$plan_file")
  echo ""
  
  # Phase 4: Documentation
  step "Phase 4: Documentation"
  info "Doc gardener will be spawned after review is complete"
  local doc_session=$(spawn_agent_real "doc-gardener" "$task_id" "Update documentation" "$plan_file")
  echo ""
  
  success "Orchestration workflow initiated!"
  echo ""
  info "All agent scripts have been generated."
  info "To execute agents:"
  echo ""
  echo "  1. Design Agent:"
  echo "     bash $AGENT_DIR/sessions/${task_id}-design.sh"
  echo ""
  echo "  2. Builder Agent (after design):"
  echo "     bash $AGENT_DIR/sessions/${task_id}-builder.sh"
  echo ""
  echo "  3. Reviewer Agent (after PR):"
  echo "     bash $AGENT_DIR/sessions/${task_id}-reviewer.sh"
  echo ""
  echo "  4. Doc Gardener (after review):"
  echo "     bash $AGENT_DIR/sessions/${task_id}-doc-gardener.sh"
  echo ""
  info "Monitor progress: agent-orchestrator status"
  info "Watch real-time: agent-orchestrator watch"
  echo ""
  info "Task plan: $plan_file"
  echo ""
}

# Show status
cmd_status() {
  init_project
  
  echo ""
  info "Agent Swarm Status"
  echo ""
  
  # Active tasks
  local active_count=$(find "$PLANS_DIR/active" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo "📋 Active tasks: $active_count"
  if [[ $active_count -gt 0 ]]; then
    find "$PLANS_DIR/active" -name "*.md" 2>/dev/null | while read -r file; do
      local task_id=$(basename "$file" .md)
      local task_name=$(grep "^# Task:" "$file" | sed 's/# Task: //')
      echo "  - $task_id: $task_name"
    done
  fi
  echo ""
  
  # In-progress tasks
  local progress_count=$(find "$PLANS_DIR/in-progress" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo "🔄 In progress: $progress_count"
  if [[ $progress_count -gt 0 ]]; then
    find "$PLANS_DIR/in-progress" -name "*.md" 2>/dev/null | while read -r file; do
      local task_id=$(basename "$file" .md)
      local task_name=$(grep "^# Task:" "$file" | sed 's/# Task: //')
      local pr_num=$(grep "**PR Number:**" "$file" | sed 's/.*: //')
      echo "  - $task_id: $task_name"
      [[ "$pr_num" != "TBD" ]] && echo "    PR: $pr_num"
    done
  fi
  echo ""
  
  # Completed tasks
  local completed_count=$(find "$PLANS_DIR/completed" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo "✅ Completed: $completed_count"
  if [[ $completed_count -gt 0 ]]; then
    find "$PLANS_DIR/completed" -name "*.md" 2>/dev/null | head -5 | while read -r file; do
      local task_id=$(basename "$file" .md)
      local task_name=$(grep "^# Task:" "$file" | sed 's/# Task: //')
      echo "  - $task_id: $task_name"
    done
    [[ $completed_count -gt 5 ]] && echo "  ... and $((completed_count - 5)) more"
  fi
  echo ""
  
  # Active agent sessions
  if [[ -d "$AGENT_DIR/sessions" ]]; then
    local session_count=$(find "$AGENT_DIR/sessions" -name "*.json" 2>/dev/null | wc -l | tr -d ' ')
    if [[ $session_count -gt 0 ]]; then
      echo "🤖 Active agent sessions: $session_count"
      find "$AGENT_DIR/sessions" -name "*.json" 2>/dev/null | while read -r session; do
        local role=$(jq -r '.role' "$session" 2>/dev/null || echo "unknown")
        local task_id=$(jq -r '.task_id' "$session" 2>/dev/null || echo "unknown")
        echo "  - $role ($task_id)"
      done
      echo ""
    fi
  fi
  
  # Recent activity
  if [[ -f "$AGENT_DIR/logs/orchestrator.log" ]]; then
    echo "Recent activity:"
    tail -5 "$AGENT_DIR/logs/orchestrator.log" 2>/dev/null | while read -r line; do
      echo "  $line"
    done
    echo ""
  fi
}

# Watch in real-time
cmd_watch() {
  init_project
  
  info "Watching agent swarm (Ctrl+C to stop)..."
  echo ""
  
  while true; do
    clear
    cmd_status
    echo "Last update: $(date)"
    echo ""
    info "Refreshing in 5 seconds..."
    sleep 5
  done
}

# Stop agents
cmd_stop() {
  local task_id="${1:-}"
  
  if [[ -n "$task_id" ]]; then
    warn "Stopping agents for task: $task_id"
    rm -f "$AGENT_DIR/sessions/${task_id}-"*.json
    rm -f "$AGENT_DIR/sessions/${task_id}-"*.sh
    success "Stopped agents for $task_id"
  else
    warn "Stopping all agents..."
    rm -f "$AGENT_DIR/sessions/"*.json
    rm -f "$AGENT_DIR/sessions/"*.sh
    success "All agents stopped"
  fi
}

# Main
main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  
  local command="$1"
  shift
  
  case "$command" in
    run)
      cmd_run "$@"
      ;;
    status)
      cmd_status
      ;;
    watch)
      cmd_watch
      ;;
    stop)
      cmd_stop "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      error "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
